# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Community host
# Host only. Keep /community out of this value.
COMMUNITY_DOMAIN=https://shawnidea.com
COMMUNITY_UPLOAD_PATH=/var/www/tech-community/uploads

# MySQL
COMMUNITY_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/community?characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
COMMUNITY_DATASOURCE_USERNAME=root
COMMUNITY_DATASOURCE_PASSWORD=change-me

# Mail
COMMUNITY_MAIL_USERNAME=your-mail-account
COMMUNITY_MAIL_PASSWORD=your-mail-password

# Redis
COMMUNITY_REDIS_DATABASE=0
COMMUNITY_REDIS_HOST=127.0.0.1
COMMUNITY_REDIS_PORT=6379
COMMUNITY_REDIS_PASSWORD=

# Kafka
COMMUNITY_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
COMMUNITY_KAFKA_ENABLED=true

# Elasticsearch
COMMUNITY_ELASTICSEARCH_URIS=http://127.0.0.1:9200
COMMUNITY_ELASTICSEARCH_ENABLED=true
COMMUNITY_ELASTICSEARCH_ADMIN_SYNC_ENABLED=false

# wkhtmltoimage
COMMUNITY_WKHTMLTOIMAGE_COMMAND=/usr/local/bin/wkhtmltoimage
COMMUNITY_WK_IMAGE_STORAGE=/var/www/tech-community/share

# Cloudflare R2
COMMUNITY_R2_ACCOUNT_ID=change-me
COMMUNITY_R2_ACCESS_KEY_ID=change-me
COMMUNITY_R2_SECRET_ACCESS_KEY=change-me
COMMUNITY_R2_HEADER_BUCKET=community-header
COMMUNITY_R2_SHARE_BUCKET=community-share
COMMUNITY_R2_HEADER_PUBLIC_BASE_URL=https://pub-your-header-bucket.r2.dev
COMMUNITY_R2_SHARE_PUBLIC_BASE_URL=https://pub-your-share-bucket.r2.dev
